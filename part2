import React, { useState } from "react";

/**
 * OrderForm Component
 * Demonstrates handling multiple input types (text, number, textarea, select)
 * using a single state object for cleaner, scalable code.
 */
function OrderForm() {
  const [formData, setFormData] = useState({
    name: "",
    quantity: 1,
    comment: "",
    paymentMethod: "",
  });

  // A single change handler for all inputs!
  const handleChange = (event) => {
    const { name, value } = event.target;
    
    setFormData((prevData) => ({
      ...prevData,
      [name]: value, // Dynamically updates the correct field
    }));
  };

  return (
    <div className="container" style={{ display: "flex", gap: "2rem", padding: "20px" }}>
      {/* Form Section */}
      <div className="card" style={{ flex: 1 }}>
        <h2>📝 Order Form</h2>

        <div style={{ display: "grid", gap: "10px" }}>
          <input
            name="name" // The 'name' must match the key in formData
            value={formData.name}
            onChange={handleChange}
            placeholder="Enter your name"
          />

          <input
            name="quantity"
            type="number"
            min="1"
            value={formData.quantity}
            onChange={handleChange}
          />

          <textarea
            name="comment"
            value={formData.comment}
            onChange={handleChange}
            placeholder="Leave your comment here"
          />

          <select name="paymentMethod" value={formData.paymentMethod} onChange={handleChange}>
            <option value="">Select payment</option>
            <option value="Visa">Visa</option>
            <option value="MasterCard">MasterCard</option>
            <option value="PayPal">PayPal</option>
          </select>
        </div>
      </div>

      {/* Summary Section */}
      <div className="table-card" style={{ flex: 1, borderLeft: "1px solid #ccc", paddingLeft: "20px" }}>
        <h3>📊 Summary</h3>
        <table style={{ textAlign: "left", width: "100%" }}>
          <tbody>
            <tr>
              <th>Name:</th>
              <td>{formData.name || "---"}</td>
            </tr>
            <tr>
              <th>Quantity:</th>
              <td>{formData.quantity}</td>
            </tr>
            <tr>
              <th>Comment:</th>
              <td>{formData.comment || "No comment"}</td>
            </tr>
            <tr>
              <th>Payment:</th>
              <td>{formData.paymentMethod || "Not selected"}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  );
}

